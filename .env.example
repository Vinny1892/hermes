# Hermes configuration
# Copy to .env and adjust as needed.
#
# Note: `dx serve` controls HOST/PORT automatically.
# These settings apply to production mode (cargo run --features server).

# Server bind address and port
HOST=0.0.0.0
PORT=8080

# Public-facing base URL (used for WebSocket signaling URLs).
# Defaults to http://localhost:$PORT if not set.
# In dev mode, the JS client rewrites the URL to use the browser's origin.
# BASE_URL=https://hermes.example.com

# SQLite database path
DATABASE_URL=sqlite:hermes.db

# Log level (see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=hermes=info
